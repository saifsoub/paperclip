# =============================================
# API ENABLE OPTION (exactly what you asked for)
# =============================================
# true  = use cheaper proxy (OpenRouter, DeepSeek, etc.)
# false = direct Anthropic (original expensive mode)
ENABLE_API_PROXY=true

# =============================================
# API KEYS — STORE LOCALLY ONLY
# =============================================
# 1. NEVER paste any key here in chat
# 2. Copy this file to .env (or .env.local)
# 3. Fill keys in your local .env file only
# 4. .gitignore already excludes .env — safe forever

# Your key goes here (OpenRouter key if ENABLE_API_PROXY=true)
ANTHROPIC_API_KEY=sk-...

# Only needed if ENABLE_API_PROXY=true
ANTHROPIC_BASE_URL=https://openrouter.ai/api

# =============================================
# Existing settings (unchanged)
# =============================================
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
